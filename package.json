{
  "name": "scm-nodecg",
  "version": "1.0.0",
  "description": "NodeCG project used for the Souls Charity Marathons",
  "homepage": "https://github.com/scmorganizers/scm-nodecg#readme",
  "license": "MIT",
  "author": "StenniHub",
  "scripts": {
    "autofix": "run-s autofix:*",
    "autofix:browser": "eslint --fix --ext .ts,.vue src/dashboard && eslint --fix --ext .ts,.vue src/graphics && eslint --fix --ext .ts src/browser_shared",
    "autofix:extension": "eslint --fix --ext .ts src/extension && eslint --fix --ext .d.ts src/types",
    "build": "run-s build:*",
    "build:browser": "cross-env NODE_ENV=production webpack",
    "build:extension": "tsc -b tsconfig.extension.json",
    "clean": "trash node_modules/.cache && trash nodecg/dashboard && trash nodecg/graphics && trash nodecg/extension",
    "format": "prettier --write ./src",
    "schema-types": "nodecg schema-types",
    "watch": "run-p watch:*",
    "watch:browser": "webpack -w",
    "watch:extension": "tsc -b tsconfig.extension.json -w",
    "start": "cross-env NODECG_ROOT=$INIT_CWD/nodecg nodecg start"
  },
  "dependencies": {
    "@types/bluebird": "^3.5.37",
    "@types/deep-equal": "^1.0.1",
    "@types/numeral": "^2.0.2",
    "@types/request-promise": "^4.1.48",
    "bluebird": "^3.7.2",
    "deep-equal": "^2.0.5",
    "eventsource": "^2.0.2",
    "fitty": "^2.3.5",
    "module-alias": "^2.2.2",
    "needle": "^3.0.0",
    "node-fetch": "^2.7.0",
    "numeral": "^2.0.6",
    "obs-websocket-js": "^5.0.3",
    "reconnecting-websocket": "^4.4.0",
    "request-promise": "^4.2.6",
    "socket.io-client": "^2.4.0",
    "websocket": "^1.0.34",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@fontsource/roboto": "^4.5.1",
    "@mdi/font": "^6.5.95",
    "@types/clone": "^2.1.1",
    "@types/module-alias": "^2.0.1",
    "@types/needle": "^2.5.2",
    "@types/node": "^16.11.11",
    "@types/webpack-env": "^1.16.3",
    "@types/websocket": "^1.0.9",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^5.6.0",
    "@typescript-eslint/parser": "^5.6.0",
    "@vue/component-compiler-utils": "^3.3.0",
    "clone": "^2.1.2",
    "cross-env": "^10.1.0",
    "css-loader": "^6.5.1",
    "deepmerge": "^4.2.2",
    "eslint": "^8.4.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^16.1.0",
    "eslint-import-resolver-typescript": "^2.5.0",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-vue": "^8.2.0",
    "file-loader": "^6.2.0",
    "fork-ts-checker-webpack-plugin": "^6.5.0",
    "globby": "^12.0.2",
    "gsap": "^3.8.0",
    "html-webpack-plugin": "^5.5.0",
    "mini-css-extract-plugin": "^2.4.5",
    "nodecg": "^2.5.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.7.1",
    "sass": "~1.32",
    "sass-loader": "^12.3.0",
    "trash-cli": "^5.0.0",
    "ts-loader": "^9.2.6",
    "tsconfig-paths-webpack-plugin": "^3.5.2",
    "typescript": "^4.5.2",
    "vue": "^2.6.14",
    "vue-class-component": "^7.2.6",
    "vue-eslint-parser": "^8.0.1",
    "vue-hot-reload-api": "^2.3.4",
    "vue-loader": "^15.9.8",
    "vue-property-decorator": "^9.1.2",
    "vue-style-loader": "^4.1.3",
    "vue-template-compiler": "^2.6.14",
    "vuetify": "^2.6.1",
    "vuetify-loader": "^1.7.3",
    "vuex": "^3.6.2",
    "vuex-class": "^0.3.2",
    "vuex-module-decorators": "^1.2.0",
    "webpack": "^5.65.0",
    "webpack-cli": "^4.9.1",
    "webpack-livereload-plugin": "^3.0.2"
  }
}
